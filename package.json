{
  "name": "@api/microservices",
  "private": true,
  "version": "1.0.0",
  "description": "api microservices",
  "workspaces": [
    "libs/config",
    "libs/common"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"**/*.ts\" --ignore-pattern node_modules --ignore-pattern dist",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "build:common": "nest build common",
    "build:config": "nest build config",
    "build:all": "bun run build:config && bun run build:common && nest build",
    "publish:common": "npm publish dist/common --access public"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@api/common": "workspace:*",
    "@api/config": "workspace:*",
    "@fastify/static": "^8.1.1",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.3.2",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.26.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.24",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "@types/node": "^22.15.17",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  },
  "trustedDependencies": [
    "@nestjs/core",
    "@swc/core"
  ]
}
